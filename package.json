{
  "name": "agent-bridge",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "面向本机命令行 Agent 的多通讯软件桥接器",
  "bin": {
    "agent-bridge": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "qrcode-terminal": "0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
